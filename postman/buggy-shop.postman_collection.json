{
  "info": {
    "name": "Buggy Shop QA Practice API",
    "description": "Manual API testing collection for Buggy Shop QA Practice API. Set variable base_url to your Cloudflare Worker URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8787"
    }
  ],
  "item": [
    {
      "name": "REQ-001 Health check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Status is ok', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "REQ-002 Products list schema",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/products"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Response is an array', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "});",
              "pm.test('Every product has numeric id and price', function () {",
              "  const json = pm.response.json();",
              "  json.forEach(product => {",
              "    pm.expect(product.id).to.be.a('number');",
              "    pm.expect(product.price).to.be.a('number');",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "REQ-004 Missing product should return 404",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/products/999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "REQ-005 Valid login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"qa@example.com\",\n  \"password\": \"correct-password\"\n}"
        },
        "url": "{{base_url}}/api/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Token exists', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.eql('demo-token-user');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "REQ-006 Invalid login should return 401",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"qa@example.com\",\n  \"password\": \"wrong-password\"\n}"
        },
        "url": "{{base_url}}/api/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "REQ-008 Order without product_id should return 400",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"quantity\": 1\n}"
        },
        "url": "{{base_url}}/api/orders"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 400', function () { pm.response.to.have.status(400); });"
            ]
          }
        }
      ]
    }
  ]
}
